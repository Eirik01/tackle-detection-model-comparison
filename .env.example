# ─────────────────────────────────────────────────────────────────────
# Environment configuration for tackle-detection-model-comparison.
#
# Copy this file to `.env` (which is gitignored) and fill in the values for
# your machine. `src/config.py` loads `.env` automatically via python-dotenv,
# and `setup.sh` exports it for the SLURM run scripts.
# ─────────────────────────────────────────────────────────────────────

# ── Secrets (required for the runs that need them) ───────────────────

# Access token for the gated DINOv3 weights on Hugging Face. Required to
# extract DINOv3 features (pipelines 1 & 2). Create it on your Hugging Face
# account after being granted access to the facebook/dinov3-* models.
DINOv3_key=

# Password for the SoccerNet v2 video download. Only needed to run the
# soccernet_experiment/ qualitative check. Request it from the SoccerNet
# maintainers (see https://www.soccer-net.org/data).
SoccerNetv2_password=

# ── Storage roots (override when NOT on the UiO FOX cluster) ─────────
# All TACDEC video/label/feature/model/result paths are derived from these
# two roots in src/config.py. Defaults point at the UiO FOX HPC; set them to
# local directories to run elsewhere.

# Work area — large, regenerable data (features, predictions, models, results).
# FOX_DATADIR_PATH=/cluster/work/projects/ec12/ec-eirikto

# Permanent project area — TACDEC videos + labels.
# FOX_PROJECT_AREA_PATH=/fp/projects01/ec12/ec-eirikto

# ── Optional overrides (defaults shown; uncomment a line to change it) ─

# Which frozen backbone to use. Default: dinov3
# BACKBONE_TYPE=dinov3          # dinov3 | vjepa2

# Backbone size. Default: large
# BACKBONE_SIZE=large           # dinov3: base | large   ·   vjepa2: large | huge | giant

# Random seeds. Keep both at 42 to reproduce the thesis results.
# TRAIN_SEED=42
# EXTRACTION_SEED=42

# Force CPU even when a GPU is present. Default: unset (uses CUDA when available).
# FORCE_CPU=true
